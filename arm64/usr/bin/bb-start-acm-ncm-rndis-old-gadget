#!/bin/sh -e

# SPDX-FileCopyrightText: 2013 Robert Nelson <robertcnelson@gmail.com>
#
# SPDX-License-Identifier: MIT

#Based off:
#https://github.com/beagleboard/meta-beagleboard/blob/master/meta-beagleboard-extras/recipes-support/usb-gadget/gadget-init/g-ether-load.sh

#Sync with: https://github.com/armbian/build/blob/main/packages/bsp/usb-gadget-network/setup-usbgadget-network.sh

if [ -f /etc/default/bb-mac-addr ] ; then
	. /etc/default/bb-mac-addr
elif [ -f /usr/bin/bb-setup-mac-address ] ; then
	/usr/bin/bb-setup-mac-address
	sync
	. /etc/default/bb-mac-addr
fi

if [ -f /etc/default/bb-boot ] ; then
	. /etc/default/bb-boot
fi

if [ -f /etc/default/generic-sys-mods ] ; then
	. /etc/default/generic-sys-mods
fi

log="usb_gadget:"

CONFIGFS="/sys/kernel/config/usb_gadget"

usb_serialnr="000000"
usb_product="USB Device"

#usb0 mass_storage
usb_ms_stall=0
usb_ms_cdrom=0
usb_ms_nofua=1
usb_ms_removable=1
usb_ms_ro=1
usb_ms_imagefile=/etc/bbb.io/templates/beagle-getting-started.img

#mac address:
#cpsw_0_mac = eth0 - wlan0 (in eeprom)
#cpsw_1_mac = usb0 (BeagleBone Side) (in eeprom)
#cpsw_2_mac = usb0 (USB host, pc side) ((cpsw_0_mac + cpsw_2_mac) /2 )
#cpsw_3_mac = wl18xx (AP) (cpsw_0_mac + 3)
#cpsw_4_mac = usb1 (BeagleBone Side)
#cpsw_5_mac = usb1 (USB host, pc side)

deviceinfo_usb_imanufacturer="$(cat /proc/device-tree/model | awk '{print $1}' | tr -d '\000')"
deviceinfo_usb_iproduct="$(cat /proc/device-tree/model | awk '{print $2}' | tr -d '\000')"

if [ -f /etc/default/usb-oem ] ; then
	. /etc/default/usb-oem
fi

#  idVendor           0x1d6b Linux Foundation
#  idProduct          0x0104 Multifunction Composite Gadget
#  bcdDevice            4.04
#  bcdUSB               2.00

# Default values for USB-related deviceinfo variables
usb_idVendor="${deviceinfo_usb_idVendor:-0x1D6B}"   # Linux Foundation
usb_idProduct="${deviceinfo_usb_idProduct:-0x0104}" # Multifunction Composite Gadget
usb_bcdDevice="${deviceinfo_usb_bcdDevice:-0x0404}"
usb_bcdUSB="${deviceinfo_usb_bcdUSB:-0x0200}"

usb_imanufacturer="${deviceinfo_usb_imanufacturer:-BeagleBoard.org}"
usb_serialnumber="${deviceinfo_usb_serialnumber:-1234BBBK5678}"
usb_iproduct="${deviceinfo_usb_iproduct:-BeagleBone}"


run_libcomposite () {
	if [ ! -d ${CONFIGFS}/g_multi/ ] ; then
		echo "${log} Setting up g_multit through configfs"
		# Create an usb gadet configuration
		mkdir -p ${CONFIGFS}/g_multi || echo "${log} Couldn't create $CONFIGFS/g_multi"

		echo "$usb_idVendor" > "$CONFIGFS/g_multi/idVendor"
		echo "$usb_idProduct" > "$CONFIGFS/g_multi/idProduct"
		echo "$usb_bcdDevice" > "$CONFIGFS/g_multi/bcdDevice"
		echo "$usb_bcdUSB" > "$CONFIGFS/g_multi/bcdUSB"

		# Create english (0x409) strings
		mkdir $CONFIGFS/g_multi/strings/0x409 || echo "${log} Couldn't create $CONFIGFS/g_multi/strings/0x409"

		echo "$usb_imanufacturer" > "$CONFIGFS/g_multi/strings/0x409/manufacturer"
		echo "$usb_iserialnumber" > "$CONFIGFS/g_multi/strings/0x409/serialnumber"
		echo "$usb_iproduct" > "$CONFIGFS/g_multi/strings/0x409/product"

		# Windows extension to use IAD (Interface Association Descriptor)
		# https://learn.microsoft.com/en-us/windows-hardware/drivers/usbcon/usb-interface-association-descriptor
		echo "0xEF" > "$CONFIGFS/g_multi/bDeviceClass"
		echo "0x02" > "$CONFIGFS/g_multi/bDeviceSubClass"
		echo "0x01" > "$CONFIGFS/g_multi/bDeviceProtocol"
		echo "0x0100" > "$CONFIGFS/g_multi/bcdDevice"

		mkdir -p $CONFIGFS/g_multi/configs/c.1/strings/0x409 || echo "${log} Couldn't create $CONFIGFS/g_multi/configs/c.1/strings/0x409"
		echo "BeagleBone Composite" > "$CONFIGFS/g_multi/configs/c.1/strings/0x409/configuration"
		echo "500" > "$CONFIGFS/g_multi/configs/c.1/MaxPower"

		# Enable use of OS descriptor (for windows to bind drivers like NCM, RNDIS...
		# without additional .inf file)
		if [ ! -d $CONFIGFS/g_multi/os_desc ] ; then
			mkdir $CONFIGFS/g_multi/os_desc || echo "${log} Couldn't create $CONFIGFS/g_multi/os_desc"
		fi
		echo "1" > "$CONFIGFS/g_multi/os_desc/use"
		echo "0xbc" > "$CONFIGFS/g_multi/os_desc/b_vendor_code"
		echo "MSFT100" > "$CONFIGFS/g_multi/os_desc/qw_sign"

		mkdir -p functions/ncm.usb0

		# Create network function.
		mkdir $CONFIGFS/g_multi/functions/ncm.usb0 || echo "${log} Couldn't create $CONFIGFS/g_multi/functions/ncm.usb0"

		#Set compatible id so that Windows 10 can match this function to
		#NCM driver more easily.
		mkdir -p $CONFIGFS/g_multi/functions/ncm.usb0/os_desc/interface.ncm || echo "${log} Couldn't create $CONFIGFS/g_multi/functions/ncm.usb0/os_desc/interface.ncm"
		echo "WINNCM" > "$CONFIGFS/g_multi/functions/ncm.usb0/os_desc/interface.ncm/compatible_id"

		if [ ! "x${USB0_HOST_ADDR}" = "x" ] ; then
			echo "$USB0_HOST_ADDR" > "$CONFIGFS/g_multi/functions/ncm.usb0/host_addr"
			echo "$USB0_DEV_ADDR" > "$CONFIGFS/g_multi/functions/ncm.usb0/dev_addr"
		fi

		# Link the network instance to the configuration
		ln -s $CONFIGFS/g_multi/functions/ncm.usb0 $CONFIGFS/g_multi/configs/c.1 || echo "${log} Couldn't symlink ncm.usb0"

		# Create Serial function.
		mkdir $CONFIGFS/g_multi/functions/acm.usb0 || echo "${log} Couldn't create $CONFIGFS/g_multi/functions/acm.usb0"

		# Link the Serial instance to the configuration
		ln -s $CONFIGFS/g_multi/functions/acm.usb0 $CONFIGFS/g_multi/configs/c.1 || echo "${log} Couldn't symlink acm.usb0"

		if [ ! "x${USB_IMAGE_FILE_DISABLED}" = "xyes" ]; then
			if [ -f ${usb_ms_imagefile} ] ; then
				echo "${log} enable USB mass_storage img file"

				# Create mass_storage function.
				mkdir $CONFIGFS/g_multi/functions/mass_storage.usb0 || echo "${log} Couldn't create $CONFIGFS/g_multi/functions/mass_storage.usb0"

				echo ${usb_ms_stall} > "$CONFIGFS/g_multi/functions/mass_storage.usb0/stall"
				echo ${usb_ms_cdrom} > "$CONFIGFS/g_multi/functions/mass_storage.usb0/lun.0/cdrom"
				echo ${usb_ms_nofua} > "$CONFIGFS/g_multi/functions/mass_storage.usb0/lun.0/nofua"
				echo ${usb_ms_removable} > "$CONFIGFS/g_multi/functions/mass_storage.usb0/lun.0/removable"
				echo ${usb_ms_ro} > "$CONFIGFS/g_multi/functions/mass_storage.usb0/lun.0/ro"
				echo ${usb_ms_imagefile} > "$CONFIGFS/g_multi/functions/mass_storage.usb0/lun.0/file"

				# Link the mass_storage instance to the configuration
				ln -s $CONFIGFS/g_multi/functions/mass_storage.usb0 $CONFIGFS/g_multi/configs/c.1 || echo "${log} Couldn't symlink mass_storage.usb0"
			fi
		fi

		###FIXME:
		sleep 1

		# Check if there's an USB Device Controller
		if [ -z "$(ls /sys/class/udc)" ]; then
			echo "${log} No USB Device Controller available"
			return
		fi

		echo "$(ls /sys/class/udc)" > $CONFIGFS/g_multi/UDC || echo "${log} Couldn't write UDC"

		echo "${log} start serial-getty@ttyGS0.service"
		systemctl start serial-getty@ttyGS0.service || true
	fi
}

use_libcomposite () {
	echo "${log} Looking for libcomposite"
	if [ -d ${CONFIGFS}/ ] ; then
		run_libcomposite
	fi
}

use_libcomposite

#
